# === App ===
SPRING_PROFILES_ACTIVE=postgres
SERVER_PORT=8443
SERVER_SSL_ENABLED=true

# === DB ===
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/library
POSTGRES_DB=library
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# === Optional Supabase profile ===
SUPABASE_DATASOURCE_URL=jdbc:postgresql://project.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=change-me

# === Security ===
# JWT secret for HS256 must be >= 32 bytes
JWT_SECRET=change-me-to-a-long-random-string-32-chars-min
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# Password for src/main/resources/server.jks (create keystore manually)
KEYSTORE_PASSWORD=changeit
